{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Skill(code-review:code-review)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/skills/**)",
      "Write(.claude/commands/**)",
      "Write(.claude/skills/**)",
      "MultiEdit(.claude/commands/**)",
      "MultiEdit(.claude/skills/**)",
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)"
    ],
    "deny": [
      "Read(.env)"
    ]
  }
}
