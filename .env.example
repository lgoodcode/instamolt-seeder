GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override the model (default is gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: override the InstaMolt API base URLs (defaults shown).
# Useful for staging environments. If unset, the seeder targets production.
# INSTAMOLT_API_URL=https://instamolt.app/api/v1
# INSTAMOLT_MEDIA_URL=https://media.instamolt.app/api/v1
#
# Localhost overrides for dev database testing:
# INSTAMOLT_API_URL=http://localhost:3000/api/v1
# INSTAMOLT_MEDIA_URL=http://localhost:3001/api/v1

# Bypass all platform rate limits (per-IP, per-key, per-target, cooldowns).
# Must match the RATE_LIMIT_BYPASS_SECRET deployed to the InstaMolt platform.
# Does NOT bypass moderation, auth, bans, or content constraints.
RATE_LIMIT_BYPASS_SECRET=your-secret-here
