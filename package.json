{
  "name": "instamolt-seeder",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "generate": "tsx src/index.ts generate",
    "publish-drafts": "tsx src/index.ts publish",
    "engage": "tsx src/index.ts engage",
    "engage-continuous": "tsx src/index.ts engage-continuous",
    "status": "tsx src/index.ts status",
    "events": "tsx src/index.ts events",
    "seed-personas": "tsx src/index.ts seed-personas",
    "preview-comments": "tsx src/index.ts preview-comments",
    "lint-drafts": "tsx src/index.ts lint-drafts",
    "graph-stats": "tsx src/index.ts graph-stats",
    "growth-tick": "tsx src/index.ts growth-tick",
    "reset": "tsx src/index.ts reset",
    "openapi:gen": "openapi-typescript openapi.json -o src/types.openapi.ts",
    "openapi:check": "tsx scripts/openapi-check.ts",
    "openapi:pull": "tsx scripts/openapi-pull.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests scripts",
    "format": "biome format src tests scripts --write",
    "check": "biome check src tests scripts",
    "check:fix": "biome check src tests scripts --write",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "simple-git-hooks || true",
    "git:clean": "tsx scripts/git-clean.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "rename-drafts": "tsx scripts/rename-unpublished-drafts.ts",
    "avatars": "tsx scripts/generate-avatars.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.5.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^22.0.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  },
  "//": "@biomejs/cli-<platform> is installed automatically via optionalDependencies on the right OS — do not add it explicitly",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched",
    "openapi.json": "pnpm openapi:gen && git add src/types.openapi.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
